FROM ghcr.io/boeing-platform/mcp-images/base-node:main

WORKDIR /app

# Copy package files
COPY hubspot/package*.json ./

# Copy the built application
COPY hubspot/dist ./dist
COPY hubspot/LICENSE ./

USER root

# Install only production dependencies (skip scripts since we have pre-built dist)
RUN npm ci --omit=dev --ignore-scripts && \
    npm cache clean --force

RUN cat > /boeingbot.yaml <<'EOF'
publish:
  mcpServers: [server]

mcpServers:
  server:
    command: node
    args: [/app/dist/index.js]
    env:
      NODE_ENV: production
      PRIVATE_APP_ACCESS_TOKEN: ${PRIVATE_APP_ACCESS_TOKEN}
EOF

RUN chown 1000 /boeingbot.yaml

COPY --from=ghcr.io/boeing-platform/boeingbot:v0.0.86 /usr/local/bin/boeingbot /usr/local/bin/

ENTRYPOINT ["boeingbot"]

CMD ["run", "--listen-address", ":8099", "-e", "PRIVATE_APP_ACCESS_TOKEN", "--config", "/boeingbot.yaml", "--disable-ui", "--exclude-built-in-agents"]

USER 1000
